<h1>ダッシュボード</h1>

<h1><%= @current_month.strftime("%Y年%m月") %>のダッシュボード</h1> c

<h2>カテゴリ別支出</h2>
<% @category_totals.each do |category_id, total| %>
<p><%= Category.find(category_id).name %>: <%= total %>円</p>
<% end %>

<div>
    <p>今月の支出合計: <%= @total %></p>
</div>

<div>
    <% if @budget.present? %>
    <p>今月の予算: <%= @budget.amount %></p>
    <p>残額: <%= @budget.amount - @total %></p>
    <p><%= link_to "予算を更新する", edit_budget_path(@budget) %></p>
    <% else %>
    <p>予算が設定されていません</p>
    <%= link_to "予算を設定する", new_budget_path %>
    <% end %>
</div>

<div>
    <%= link_to "支出を追加する",new_expense_path %>
</div>
<%= link_to "← #{@current_month.prev_month.strftime('%Y年%m月')}", expenses_path(month: @current_month.prev_month.strftime("%Y-%m")) %>
<%= @current_month.strftime("%Y年%m月") %>
<%= link_to "#{@current_month.next_month.strftime('%Y年%m月')} →", expenses_path(month: @current_month.next_month.strftime("%Y-%m")) %>